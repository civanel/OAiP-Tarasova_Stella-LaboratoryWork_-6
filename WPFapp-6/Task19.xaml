<Window x:Class="WPFapp_6.Task19"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFapp_6"
        mc:Ignorable="d"
        Title="Индексы массива" Height="300" Width="300">
    <Grid Margin="30">
        <StackPanel>
            <TextBlock Text="Размер массива n (1-50):" Margin="0,0,0,6"/>
            <TextBox x:Name="txtN"/>

            <Button Content="Посчитать" Margin="0,24,0,0" Padding="12,6" Click="Calculate_Click"/>

            <TextBlock x:Name="tbResult" Margin="0,20,0,0" FontSize="14" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>
