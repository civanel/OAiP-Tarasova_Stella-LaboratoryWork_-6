<Window x:Class="WPFapp_6.Task10"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFapp_6"
        mc:Ignorable="d"
        Title="Футбольный чемпионат" Height="300" Width="300">
    <Grid Margin="30">
        <StackPanel>
            <TextBlock Text="Количество команд n (2-10):" Margin="0,0,0,6"/>
            <TextBox x:Name="txtN"/>
            <Button Content="Найти число команд и их номера" Margin="0,24,0,0" Padding="12,6" Click="Process_Click"/>
            <TextBlock x:Name="tbResult" Margin="0,20,0,0" FontSize="14" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>
