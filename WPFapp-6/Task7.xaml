<Window x:Class="WPFapp_6.Task7"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFapp_6"
        mc:Ignorable="d"
        Title="Task7" Height="350" Width="350">
    <Grid Margin="30">
        <StackPanel>
            <TextBlock Text="Левая граница (first):" Margin="0,0,0,6"/>
            <TextBox x:Name="txtFirst"/>
            <TextBlock Text="Правая граница (second):" Margin="0,16,0,6"/>
            <TextBox x:Name="txtSecond"/>
            <TextBlock Text="Число для проверки:" Margin="0,16,0,6"/>
            <TextBox x:Name="txtValue"/>
            <Button Content="Проверить rangecheck" Margin="0,24,0,0" Padding="12,6" Click="Check_Click"/>
            <TextBlock x:Name="tbResult" Margin="0,20,0,0" FontSize="15" TextWrapping="Wrap"/>
        </StackPanel>
    </Grid>
</Window>
