<Window x:Class="WPFapp_6.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFapp_6"
        mc:Ignorable="d"
        Title="MainMenu" Height="500" Width="800">
    <Grid Margin="30">
        <StackPanel>
            <TextBlock Text="Меню заданий" FontSize="18" FontWeight="SemiBold"
                       HorizontalAlignment="Center" Margin="0,0,0,30"/>
            <Button Content="Успеваемость студента" Margin="8" Padding="10" FontSize="14"
                    Click="OpenTask22"/>
            <Button Content="Сумма" Margin="8" Padding="10" FontSize="14"
                    Click="OpenTask16"/>
            <Button Content="Чётные и нечётные индексы" Margin="8" Padding="10" FontSize="14"
                    Click="OpenTask19"/>
            <Button Content="Футбольный чемпионат" Margin="8" Padding="10" FontSize="14"
                    Click="OpenTask10"/>
            <Button Content="Отражение матрицы по вертикали" Margin="8" Padding="10" FontSize="14"
                    Click="OpenTask3"/>
            <Button Content="Проверка чисел в диапазоне" Margin="8" Padding="10" FontSize="14"
                    Click="OpenTask7"/>
        </StackPanel>
    </Grid>
</Window>
